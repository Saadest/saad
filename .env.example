# Database
DATABASE_URL="file:./data/dev.db"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# File Upload
MAX_FILE_SIZE="5368709120"
UPLOAD_DIR="./data/uploads"
RENDERS_DIR="./data/renders"
TEMP_DIR="./data/temp"
TRANSCRIPTS_DIR="./data/transcripts"

# FFmpeg
FFMPEG_PATH="ffmpeg"
FFPROBE_PATH="ffprobe"

# AI Providers (optional - defaults to local)
# Transcription: whisper.cpp (local) or openai
TRANSCRIPTION_PROVIDER="whisper_cpp"
OPENAI_API_KEY=""

# Clip Scoring: ollama (local) or openai or anthropic
CLIP_SCORING_PROVIDER="ollama"
OLLAMA_BASE_URL="http://localhost:11434"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Storage: local (default) or s3
STORAGE_PROVIDER="local"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
